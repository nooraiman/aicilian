<%- include('include/_header') %>
        <!-- Begin Page Content -->
        <div class="container-fluid">

            <!-- Page Heading -->
            <h1 class="h3 mb-2 text-gray-800"><i class="fa fa-file"></i> Manage Menu</h1>
            <p class="mb-4">Add Menu, Edit Menu, Delete Menu, Change Price, Only the Manager have the power to manage this page</p>

            <!-- DataTales Example -->
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold">List of Menu</h6>     
                        <button style="margin-left: 90%" class="btn btn-warning btn-icon-split btn-sm " onclick="window.location.href='AddMenu.html'" >
