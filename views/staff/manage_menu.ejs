                                <tr>
                                    <th style="width: 3%;">No</th>
                                    <th>Name</th>
                                    <th>ID</th>
                                    <th>Type</th>
                                    <th>Price (RM)</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>1</td>
                                    <td>Cheeseburger</td>
                                    <td>FCB100</td>
                                    <td>Food</td>
                                    <td>14.90</td>
                                    <td>Available</td>
                                    <td><button class="btn btn-primary btn-circle btn-sm" >
                                        <span class="icon text-white">
                                            <i class="fa fa-arrow-right"></i>
                                        </span>
                                    </td>
                                </tr>                                        
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
        <!-- /.container-fluid -->

    </div>
    <!-- End of Main Content -->
