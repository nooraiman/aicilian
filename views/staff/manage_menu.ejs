                            <i class="fa fa-plus"></i>
                        </span>
                        <span class="text" >Add Menu</span>
                    </button>       
                </div>
                
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0" style="text-align: center;">
